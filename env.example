# Configuration pour Make.com et Google Drive
# Remplacez les valeurs par vos propres clés

# Webhook URLs Make.com
REACT_APP_WEBHOOK_URL=
REACT_APP_WEBHOOK_URL_FILES=
REACT_APP_SUBMISSION_STATUS_WEBHOOK=
REACT_APP_IS_CLOSING_FORM_SUBMITTED_WEBHOOK=
REACT_APP_CLOSING_FORM_SUBMIT_WEBHOOK=

# HubSpot Configuration
REACT_APP_HUBSPOT_COMPANY_ID=
REACT_APP_HUBSPOT_DEAL_ID=
REACT_APP_HUBSPOT_CONTACT_ID=

# Google Drive API Configuration
REACT_APP_GOOGLE_CLIENT_ID=
REACT_APP_GOOGLE_API_KEY=

# DocuSign API Configuration
REACT_APP_DOCUSIGN_CLIENT_ID=
REACT_APP_DOCUSIGN_CLIENT_SECRET=
REACT_APP_DOCUSIGN_ACCOUNT_ID=
REACT_APP_DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi
REACT_APP_DOCUSIGN_REDIRECT_URI=
REACT_APP_DOCUSIGN_TEMPLATE_ID=
REACT_APP_DOCUSIGN_RR_TEMPLATE_ID=

# DocuSign Envelope IDs
REACT_APP_FUTURE_PURCHASE_AGREEMENT_DOCUSIGN_ID=
REACT_APP_RR_DOCUSIGN_ID=

# Make.com Webhooks for DocuSign
REACT_APP_MAKE_DOCUSIGN_WEBHOOK_URL=
REACT_APP_MAKE_DOCUSIGN_STATUS_WEBHOOK_URL=

# ACH Direct Debit Configuration
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
REACT_APP_STRIPE_FCA_WEBHOOK=https://hook.us1.make.com/xxxxx
REACT_APP_STRIPE_CUSTOMER_ID=cus_xxxxx
REACT_APP_HUBSPOT_DEAL_ID=xxxxx
# Note: Use PUBLISHABLE key (pk_) for frontend, NOT secret key (sk_)
# FCA and FCA_secret are generated dynamically via webhook

# Mot de passe pour protéger l'accès au formulaire
REACT_APP_FORM_PASSWORD=your_secure_password_here

# Configuration de développement (optionnel)
REACT_APP_DISABLE_FORM_GUARD=false

# Instructions:
# 1. Copiez ce fichier vers .env
# 2. Configurez les URLs de webhook Make.com
# 3. Configurez les clés Google Drive API
# 4. Définissez un mot de passe sécurisé pour protéger l'accès au formulaire
# 5. Redémarrez votre serveur de développement

# Fonctionnalités:
# - Vérification du statut de soumission via Make.com
# - Upload des fichiers vers Google Drive
# - Protection par mot de passe
# - Sauvegarde automatique des données
# - Redirection automatique si formulaire déjà soumis 